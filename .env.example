# Copy this file to .env and fill in the values before running the bot.

# Telegram Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# API credentials from https://my.telegram.org/auth
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Comma-separated list of numeric Telegram user IDs that can use admin commands.
# Leave empty to disable admin commands.
ADMIN_IDS=

# Strongly recommended on cloud hosts (Render, Railway, VPS): YouTube often blocks
# datacenter IPs until requests carry a real logged-in session.
# Export Netscape-format cookies after signing into youtube.com in your browser — see:
# https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
#
# Render: create a Secret File (e.g. youtube_cookies.txt), then set:
# YTDLP_COOKIEFILE=/etc/secrets/youtube_cookies.txt
#
# YTDLP_COOKIEFILE=/path/to/cookies.txt
